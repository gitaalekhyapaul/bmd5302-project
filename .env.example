# Sandra MCP App local configuration.
# Copy to .env and fill real local values there. Do not commit .env.

# OpenAI-compatible LLM endpoint for Sandra's chat orchestrator.
# Use the provider API base URL only; do not include /chat/completions.
# NVIDIA NIM example: SANDRA_OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
# NVIDIA NIM example: SANDRA_LLM_MODEL=moonshotai/kimi-k2-instruct
SANDRA_OPENAI_API_KEY=
SANDRA_OPENAI_BASE_URL=
SANDRA_LLM_MODEL=
SANDRA_LLM_TEMPERATURE=0.2

# Upstream workbook MCP endpoint. The chat server defaults to invoking this MCP server.
SANDRA_WORKBOOK_MCP_URL=http://127.0.0.1:8000/mcp

# Optional future registry knob for adding related MCP servers.
# Example:
# SANDRA_MCP_REGISTRY_JSON=[{"name":"workbook","url":"http://127.0.0.1:8000/mcp"}]

# Local SQLite memory for Sandra's chat UI. The default lives under ignored
# notebook_outputs/ so chat state and workbook artifacts stay out of git.
SANDRA_APP_DB_PATH=notebook_outputs/sandra_app_memory.sqlite3
SANDRA_CHAT_DB_PATH=notebook_outputs/sandra_chat.sqlite3

# Standalone Sandra chat MCP App server defaults.
SANDRA_CHAT_HOST=0.0.0.0
SANDRA_CHAT_PORT=8001

# Put any future app/server credentials here instead of code or notebooks.
# Example placeholder only:
SANDRA_APP_SHARED_SECRET=
